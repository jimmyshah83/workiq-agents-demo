# GitHub Personal Access Token (needs repo, issues, pull_requests scopes)
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# GitHub organization or user to create repos under (leave empty for personal account)
GITHUB_OWNER=

# Optional: Microsoft 365 tenant ID for Work IQ (if not using default)
# WORKIQ_TENANT_ID=

# Optional: Copilot model to use (default: gpt-5)
# COPILOT_MODEL=gpt-5
